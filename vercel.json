{
  "functions": {
    "api/wsgi.py": {
      "includeFiles": "Backend/**",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "buildCommand": "cd Frontend && npm run build",
  "outputDirectory": "Frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/wsgi" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
